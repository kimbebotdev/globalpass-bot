# Environment
ENVIRONMENT=dev
BASE_URL_DEV=http://localhost:8000
BASE_URL_PROD=https://your-globalpass-domain.com

# Application
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite:///./data/globalpass.db

# Flight Output
FINAL_OUTPUT_FORMAT=default

# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# MyIDTravel Account
UAL_USERNAME=your_ual_username
UAL_PASSWORD=your_ual_password

# StaffTraveler Account
ST_USERNAME=your_stafftraveler_email
ST_PASSWORD=your_stafftraveler_password

# Admin Login
ADMIN_USERNAME=admin
# python -c "import bcrypt; print(bcrypt.hashpw(b'your_password_here', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=your_bcrypt_hash
SECRET_KEY=replace-with-a-long-random-secret

# Security
GLOBALPASS_API_KEY=your-strong-secret-key-here
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Slack
SLACK_CHANNEL_ID=your-slack-channel-id
SLACK_BOT_USER_OAUTH_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
